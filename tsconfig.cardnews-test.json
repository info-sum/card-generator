{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "erasableSyntaxOnly": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": "src",
    "outDir": ".tmp-cardnews-test"
  },
  "include": [
    "src/cardNewsDraft.ts",
    "src/cardNewsDraft.test.ts",
    "src/creationFlow.ts",
    "src/creationFlow.test.ts"
  ]
}
